<?xml version="1.0" encoding="UTF-8"?>
<configs>
    <removeattribute xpath="/recipes/recipe[@name='resourceGlue' and @craft_area='campfire']/@craft_tool"/>
    <append xpath="/recipes/recipe[@name='resourceGlue' and @craft_area='campfire']">
        <ingredient name="drinkJarEmpty" count="1"/>
    </append>

    <append xpath="/recipes">
        <recipe name="ApexBloodlinesResourceRope" count="1" craft_time="3" tags="packMuleCrafting">
            <ingredient name="resourceYuccaFibers" count="5"/>
        </recipe>

        <recipe name="ApexBloodlinesToolCrudeAxe" count="1" craft_time="8" tags="packMuleCrafting">
            <ingredient name="ApexBloodlinesResourceRope" count="2"/>
            <ingredient name="ApexBloodlinesResourceStick" count="2"/>
            <ingredient name="resourceRockSmall" count="3"/>
        </recipe>

        <recipe name="ApexBloodlinesWeaponCrudePike" count="1" craft_time="10" tags="packMuleCrafting">
            <ingredient name="ApexBloodlinesResourceBranch" count="1"/>
            <ingredient name="ApexBloodlinesResourceRope" count="2"/>
            <ingredient name="ApexBloodlinesResourceSharpStone" count="2"/>
        </recipe>

        <recipe name="ApexBloodlinesArmorBarkHelmet" count="1" craft_time="8" tags="packMuleCrafting">
            <ingredient name="ApexBloodlinesResourceBark" count="4"/>
            <ingredient name="ApexBloodlinesResourceRope" count="1"/>
            <ingredient name="ApexBloodlinesResourceStick" count="2"/>
        </recipe>
        <recipe name="ApexBloodlinesArmorBarkOutfit" count="1" craft_time="15" tags="packMuleCrafting">
            <ingredient name="ApexBloodlinesResourceBark" count="12"/>
            <ingredient name="ApexBloodlinesResourceRope" count="3"/>
            <ingredient name="ApexBloodlinesResourceStick" count="4"/>
        </recipe>
        <recipe name="ApexBloodlinesArmorBarkGloves" count="1" craft_time="8" tags="packMuleCrafting">
            <ingredient name="ApexBloodlinesResourceBark" count="5"/>
            <ingredient name="ApexBloodlinesResourceRope" count="1"/>
            <ingredient name="ApexBloodlinesResourceStick" count="2"/>
        </recipe>
        <recipe name="ApexBloodlinesArmorBarkBoots" count="1" craft_time="10" tags="packMuleCrafting">
            <ingredient name="ApexBloodlinesResourceBark" count="7"/>
            <ingredient name="ApexBloodlinesResourceRope" count="2"/>
            <ingredient name="ApexBloodlinesResourceStick" count="2"/>
        </recipe>

        <!-- Every vanilla 3.0 bedroll colour is available as an explicit craft. -->
        <recipe name="bedroll" count="1" tags="packMuleCrafting"><ingredient name="resourceYuccaFibers" count="10"/></recipe>
        <recipe name="bedrollRed" count="1" tags="packMuleCrafting"><ingredient name="resourceYuccaFibers" count="10"/></recipe>
        <recipe name="bedrollOrange" count="1" tags="packMuleCrafting"><ingredient name="resourceYuccaFibers" count="10"/></recipe>
        <recipe name="bedrollYellow" count="1" tags="packMuleCrafting"><ingredient name="resourceYuccaFibers" count="10"/></recipe>
        <recipe name="bedrollGreen" count="1" tags="packMuleCrafting"><ingredient name="resourceYuccaFibers" count="10"/></recipe>
        <recipe name="bedrollBlue" count="1" tags="packMuleCrafting"><ingredient name="resourceYuccaFibers" count="10"/></recipe>
        <recipe name="bedrollPurple" count="1" tags="packMuleCrafting"><ingredient name="resourceYuccaFibers" count="10"/></recipe>
        <recipe name="bedrollPink" count="1" tags="packMuleCrafting"><ingredient name="resourceYuccaFibers" count="10"/></recipe>
        <recipe name="bedrollGrey" count="1" tags="packMuleCrafting"><ingredient name="resourceYuccaFibers" count="10"/></recipe>
        <recipe name="bedrollWhite" count="1" tags="packMuleCrafting"><ingredient name="resourceYuccaFibers" count="10"/></recipe>
        <recipe name="bedrollArmyGreen" count="1" tags="packMuleCrafting"><ingredient name="resourceYuccaFibers" count="10"/></recipe>
    </append>
</configs>
