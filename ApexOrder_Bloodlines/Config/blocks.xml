<?xml version="1.0" encoding="UTF-8"?>
<configs>
    <!-- Starter shrubs are deliberately generous so the opening teaches survival without becoming a grind. -->
    <append xpath="/blocks/block[contains(translate(@name,'BUSHSHRUB','bushshrub'),'bush') or contains(translate(@name,'BUSHSHRUB','bushshrub'),'shrub')]">
        <drop event="Harvest" name="resourceYuccaFibers" count="2,4" prob="1" tag="allHarvest"/>
        <drop event="Harvest" name="ApexBloodlinesResourceStick" count="1,3" prob="0.80" tag="allHarvest"/>
        <drop event="Harvest" name="resourceRockSmall" count="1,2" prob="0.30" tag="allHarvest"/>
    </append>

    <!-- Crude and later axes produce the Bloodlines wood resources at useful rates. -->
    <append xpath="/blocks/block[drop[@event='Harvest' and @name='resourceWood' and contains(@tag,'oreWoodHarvest')]]">
        <drop event="Harvest" name="ApexBloodlinesResourceBark" count="2,4" prob="1" tag="oreWoodHarvest"/>
        <drop event="Harvest" name="ApexBloodlinesResourceBranch" count="1,2" prob="0.45" tag="oreWoodHarvest"/>
        <drop event="Harvest" name="ApexBloodlinesResourceStick" count="2,4" prob="0.85" tag="oreWoodHarvest"/>
    </append>

    <!-- Mining tools always return enough sharp stone to keep primitive crafting moving. -->
    <append xpath="/blocks/block[drop[@event='Harvest' and @name='resourceRockSmall']]">
        <drop event="Harvest" name="ApexBloodlinesResourceSharpStone" count="2,4" prob="1" tag="allHarvest" tool_category="ApexBloodlinesMining"/>
    </append>

    <append xpath="/blocks">
        <block name="ApexBloodlinesPrimitiveHelixReader">
            <property name="Extends" value="forge"/>
            <property name="Class" value="Workstation"/>
            <property name="CustomIcon" value="forge"/>
            <property name="CustomIconTint" value="00C878"/>
            <property name="DescriptionKey" value="ApexBloodlinesPrimitiveHelixReaderDesc"/>
            <property name="EconomicValue" value="100"/>
            <property name="SellableToTrader" value="false"/>
            <property name="CreativeMode" value="Player"/>
            <property class="Workstation">
                <property name="Modules" value="output"/>
                <property name="CraftingAreaRecipes" value="ApexBloodlinesHelixReader"/>
            </property>
        </block>
    </append>
</configs>