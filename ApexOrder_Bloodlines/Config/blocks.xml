<?xml version="1.0" encoding="UTF-8"?>
<configs>
    <append xpath="/blocks/block[contains(translate(@name,'BUSH','bush'),'bush')]">
        <drop event="Harvest" name="ApexBloodlinesResourceStick" count="1" prob="0.35" tag="allHarvest"/>
    </append>
    <append xpath="/blocks/block[starts-with(@name,'tree') and not(contains(translate(@name,'BUSH','bush'),'bush')) and not(contains(translate(@name,'STUMP','stump'),'stump'))]">
        <drop event="Harvest" name="ApexBloodlinesResourceStick" count="1" prob="0.20" tag="allHarvest"/>
        <drop event="Harvest" name="ApexBloodlinesResourceBark" count="1" prob="0.45" tag="allHarvest"/>
        <drop event="Harvest" name="ApexBloodlinesResourceBranch" count="1" prob="0.12" tag="allHarvest"/>
    </append>
    <append xpath="/blocks/block[contains(@name,'terrStone') or contains(@name,'boulder') or contains(@name,'resourceRock') or contains(@name,'rockResource')]">
        <drop event="Harvest" name="ApexBloodlinesResourceSharpStone" count="1" prob="0.15" tag="allHarvest"/>
    </append>
</configs>
