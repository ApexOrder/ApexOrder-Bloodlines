<?xml version="1.0" encoding="UTF-8"?>
<configs>
    <!-- Bushes and shrubbery provide sticks. -->
    <append xpath="/blocks/block[contains(translate(@name,'BUSHSHRUB','bushshrub'),'bush') or contains(translate(@name,'BUSHSHRUB','bushshrub'),'shrub')]">
        <drop event="Harvest" name="ApexBloodlinesResourceStick" count="1" prob="0.40" tag="allHarvest"/>
    </append>

    <!-- Add Bloodlines harvests only to real wood-yielding trees. -->
    <append xpath="/blocks/block[drop[@event='Harvest' and @name='resourceWood' and contains(@tag,'oreWoodHarvest')]]">
        <drop event="Harvest" name="ApexBloodlinesResourceBark" count="8" tag="ApexBloodlinesAxeHarvest"/>
        <drop event="Harvest" name="ApexBloodlinesResourceBranch" count="2" tag="ApexBloodlinesAxeHarvest"/>
        <drop event="Harvest" name="ApexBloodlinesResourceStick" count="2" tag="ApexBloodlinesAxeHarvest"/>
    </append>

    <!-- Sharp stone is recovered while mining stone-bearing terrain and boulders. -->
    <append xpath="/blocks/block[drop[@event='Harvest' and @name='resourceRockSmall']]">
        <drop event="Harvest" name="ApexBloodlinesResourceSharpStone" count="1" prob="0.12" tag="allHarvest"/>
    </append>
</configs>
