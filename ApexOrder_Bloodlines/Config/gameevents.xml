<?xml version="1.0" encoding="UTF-8"?>
<configs>
    <!--
        7DTD 3.0.1 awards its opening quest from the
        challenge_group_reward_basics action sequence.
        Redirect that exact vanilla AddQuest action to Bloodlines.
    -->
    <setattribute
        xpath="/gameevents/action_sequence[@name='challenge_group_reward_basics']/action[@class='AddQuest']/property[@name='quest' and @value='quest_whiteRiverCitizen1']"
        name="value">quest_ApexBloodlines_01_Awakening</setattribute>
</configs>
