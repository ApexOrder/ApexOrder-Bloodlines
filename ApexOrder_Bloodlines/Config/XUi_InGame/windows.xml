<?xml version="1.0" encoding="UTF-8"?>
<configs>
    <append xpath="/windows">
        <window name="windowApexBloodlinesHelixReaderList"
                width="397"
                height="688"
                controller="CraftingListInfo"
                panel="Left"
                cursor_area="true">

            <rect name="frame" width="397" height="688" depth="0">
                <sprite depth="0" name="outerGlow" sprite="menu_empty3px" width="397" height="688" color="0,230,138,90" type="sliced" fillcenter="false"/>
                <sprite depth="1" name="background" sprite="menu_empty3px" pos="3,-3" width="391" height="682" color="5,16,18,245" type="sliced"/>

                <rect name="header" pos="6,-6" width="385" height="72" depth="2">
                    <sprite depth="2" name="headerBackground" sprite="menu_empty3px" width="385" height="72" color="7,42,37,255" type="sliced"/>
                    <sprite depth="3" name="headerLine" sprite="menu_empty" pos="0,-68" width="385" height="4" color="0,230,138,255"/>
                    <sprite depth="4" name="helixIcon" sprite="ui_game_symbol_science" size="42,42" pos="28,-35" pivot="center" color="0,230,138,255" foregroundlayer="true"/>
                    <label depth="4" name="title" pos="58,-11" width="315" height="32" text="HELIX ANALYSIS" font_size="32" color="0,230,138,255" upper_case="true"/>
                    <label depth="4" name="subtitle" pos="58,-42" width="315" height="24" text="SELECT CORE PROTOCOL" font_size="22" color="170,220,205,255"/>
                </rect>

                <rect name="statusPanel" pos="12,-90" width="373" height="94" depth="2">
                    <sprite depth="2" name="statusBackground" sprite="menu_empty3px" width="373" height="94" color="8,25,27,255" type="sliced"/>
                    <label depth="3" name="statusTitle" pos="14,-12" width="345" height="26" text="READER STATUS" font_size="24" color="0,230,138,255"/>
                    <label depth="3" name="statusLine1" pos="14,-42" width="345" height="24" text="CORE INTERFACE: READY" font_size="22" color="210,235,225,255"/>
                    <label depth="3" name="statusLine2" pos="14,-66" width="345" height="24" text="GENETIC ARCHIVE: DORMANT" font_size="22" color="130,175,165,255"/>
                </rect>

                <rect name="recipePanel" pos="12,-202" width="373" height="468" depth="2" on_scroll="true">
                    <sprite depth="2" name="recipeBackground" sprite="menu_empty3px" width="373" height="468" color="4,12,14,255" type="sliced"/>
                    <label depth="3" name="recipeHeader" pos="14,-12" width="345" height="28" text="AVAILABLE ANALYSIS" font_size="25" color="0,230,138,255"/>
                    <grid name="recipes"
                          depth="4"
                          rows="8"
                          cols="1"
                          pos="9,-52"
                          width="355"
                          height="400"
                          cell_width="355"
                          cell_height="49"
                          controller="RecipeList"
                          repeat_content="true"
                          arrangement="vertical">
                        <recipe_entry name="0"/>
                    </grid>
                </rect>
            </rect>
        </window>

        <window name="windowApexBloodlinesHelixReaderQueue"
                width="397"
                height="96"
                panel="Left"
                cursor_area="true"
                always_update="true">
            <rect name="queueFrame" width="397" height="96">
                <sprite depth="0" name="outerGlow" sprite="menu_empty3px" width="397" height="96" color="0,230,138,90" type="sliced" fillcenter="false"/>
                <sprite depth="1" name="background" sprite="menu_empty3px" pos="3,-3" width="391" height="90" color="5,16,18,245" type="sliced"/>
                <label depth="3" name="queueTitle" pos="14,-12" width="150" height="26" text="SEQUENCING" font_size="23" color="0,230,138,255"/>
                <rect depth="2" pos="92,-8" width="296" height="82" controller="CraftingQueue" always_update="true">
                    <grid name="queue" rows="1" cols="4" pos="3,-3" cell_width="72" cell_height="72" repeat_content="true" always_update="true">
                        <recipe_stack name="0"/>
                    </grid>
                </rect>
            </rect>
        </window>

        <window name="windowApexBloodlinesHelixReaderOutput"
                width="228"
                height="198"
                anchor="Top"
                panel="Right"
                cursor_area="true"
                controller="WorkstationOutputWindow">
            <rect name="outputFrame" width="228" height="198">
                <sprite depth="0" name="outerGlow" sprite="menu_empty3px" width="228" height="198" color="0,230,138,90" type="sliced" fillcenter="false"/>
                <sprite depth="1" name="background" sprite="menu_empty3px" pos="3,-3" width="222" height="192" color="5,16,18,245" type="sliced"/>

                <rect name="header" pos="6,-6" width="216" height="58">
                    <sprite depth="2" name="headerBackground" sprite="menu_empty3px" width="216" height="58" color="7,42,37,255" type="sliced"/>
                    <sprite depth="3" name="headerLine" sprite="menu_empty" pos="0,-54" width="216" height="4" color="0,230,138,255"/>
                    <label depth="4" name="outputTitle" pos="12,-14" width="192" height="30" text="CORE OUTPUT" font_size="27" color="0,230,138,255" justify="center"/>
                </rect>

                <rect name="content" depth="2" pos="76,-78" width="76" height="76" disablefallthrough="true">
                    <sprite depth="2" name="slotGlow" sprite="menu_empty3px" pos="-4,4" width="84" height="84" color="0,230,138,120" type="sliced" fillcenter="false"/>
                    <grid depth="10" name="inventory" rows="1" cols="1" pos="0,0" cell_width="75" cell_height="75" controller="WorkstationOutputGrid" repeat_content="true">
                        <item_stack name="0"/>
                    </grid>
                </rect>

                <label depth="4" name="outputHint" pos="12,-164" width="204" height="24" text="RETRIEVE ANALYSED CORE" font_size="20" color="150,195,183,255" justify="center"/>
            </rect>
        </window>
    </append>
</configs>